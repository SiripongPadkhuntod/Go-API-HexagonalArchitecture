PORT=8080

# --- Database Configuration ---
# Set DATABASE_DRIVER to "mysql" to use MySQL, or "postgres" for PostgreSQL
DATABASE_DRIVER=postgres

# PostgreSQL example:
DATABASE_HOST=localhost
DATABASE_PORT=5439
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=hexagonal_architecture
DATABASE_SSLMODE=disable

# MySQL example (uncomment to use MySQL):
# DATABASE_DRIVER=mysql
# DATABASE_HOST=localhost
# DATABASE_PORT=3307
# DATABASE_USER=mysql
# DATABASE_PASSWORD=mysql
# DATABASE_NAME=hexagonal_architecture
# DATABASE_SSLMODE=disable

# Optional. Leave empty to use the no-op outbound adapter.
OUTBOUND_API_BASE_URL=https://multi-branch-inventory-pos-system.onrender.com

# --- Storage Configuration (MinIO) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=root
MINIO_SECRET_KEY=password123
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=uploads
